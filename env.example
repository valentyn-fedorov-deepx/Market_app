DATABASE_URL=sqlite:///./market_analyzer.db
CSV_FALLBACK_PATH=data/synthetic_djinni_vacancies_updated.csv
CSV_FALLBACK_LIMIT=25000
ENABLE_REMOTE_SOURCES=true

REMOTIVE_API_URL=https://remotive.com/api/remote-jobs
REMOTIVE_LIMIT=1000

ADZUNA_ENABLED=false
ADZUNA_API_URL=https://api.adzuna.com/v1/api/jobs
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=gb
ADZUNA_RESULTS_PER_PAGE=50
ARBEITNOW_ENABLED=false
ARBEITNOW_API_URL=https://www.arbeitnow.com/api/job-board-api
ARBEITNOW_MAX_PAGES=10

REMOTEOK_ENABLED=true
REMOTEOK_API_URL=https://remoteok.com/api
HF_LINKEDIN_ENABLED=true
HF_LINKEDIN_LIMIT=33246
HF_7M_ENABLED=true
HF_7M_LIMIT=80000

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=mistral:7b-instruct
OLLAMA_TIMEOUT_SECONDS=300
LLM_PROVIDER=ollama
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_API_MODEL=
LLM_API_REFERER=
LLM_API_TITLE=Market Analyzer App
ASSISTANT_LLM_ENABLED=true
ASSISTANT_MAX_TOKENS=192
ASSISTANT_TEMPERATURE=0.2

REFRESH_ON_STARTUP=false
REFRESH_INTERVAL_MINUTES=360

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost,http://127.0.0.1
CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?
